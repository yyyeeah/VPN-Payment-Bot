BOT_TOKEN=123456:replace-me

# Либо задайте ADMIN_CHAT_ID сразу, либо оставьте его пустым
# и назначьте админ-чат из Telegram через /admin <ADMIN_CODE> после запуска.
ADMIN_CHAT_ID=
ADMIN_CODE=change-me

DATABASE_PATH=bot.sqlite3
TIMEZONE=Asia/Yekaterinburg
PAYMENT_DESTINATION_TEXT=replace-with-your-bank-details
# День окончания подписки напоминается всегда; здесь задаются дополнительные дни до него.
REMINDER_DAYS_BEFORE=1
OVERDUE_REMINDER_INTERVAL_DAYS=1
DAILY_REMINDER_TIME=10:00
LOG_LEVEL=INFO

# Шаблоны напоминаний. Поддерживаются подстановки:
# {customer_name} {admin_customer_name} {expires_on} {days_left} {days_left_text}
# {overdue_days} {overdue_text} {payment_details} {payment_amount_line} {access_disable_warning}
# {amount} {device_count} {device_count_label}
# {client_code} {telegram_user_id} {username} {status}
REMINDER_BEFORE_DUE_TEMPLATE=
REMINDER_DUE_TODAY_TEMPLATE=
REMINDER_OVERDUE_TEMPLATE=
ADMIN_OVERDUE_REMINDER_TEMPLATE=
